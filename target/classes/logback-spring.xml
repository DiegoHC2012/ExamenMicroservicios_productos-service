<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Console appender (standard) -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- CloudWatch appender → LocalStack -->
    <appender name="CLOUDWATCH" class="com.examen.productosservice.config.CloudWatchAppender">
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>INFO</level>
        </filter>
        <logGroupName>producto-log-group</logGroupName>
        <logStreamName>productos-stream</logStreamName>
        <endpoint>http://localstack:4566</endpoint>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="CLOUDWATCH"/>
    </root>

</configuration>
